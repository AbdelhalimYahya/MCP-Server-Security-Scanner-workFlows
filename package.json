{
  "name": "mcp-scan",
  "version": "0.1.0",
  "description": "A security scanner for MCP (Model Context Protocol) servers — detects vulnerabilities like plaintext secrets, insecure bindings, dangerous tool permissions, and more",
  "keywords": [
    "mcp",
    "security",
    "scanner",
    "model-context-protocol",
    "audit"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbdelhalimYahya/MCP-Server-Security-Scanner-workFlows.git"
  },
  "type": "module",
  "bin": {
    "mcp-scan": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.0.0",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.6.0"
  }
}
